<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700" prefWidth="1100" style="-fx-background-color: #f5f0e8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.electricity.cms.controller.CustomerDashboardController">

    <!-- ═══════════════════════════════════════════════════════
         HEADER
    ═══════════════════════════════════════════════════════ -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: #2e7d32; -fx-padding: 0 24 0 24; -fx-min-height: 60; -fx-max-height: 60;">

                <!-- Logo / App name -->
                <Label style="-fx-text-fill: #f5f0e8; -fx-font-size: 22px; -fx-font-weight: bold; -fx-font-family: 'Georgia';" text="⚡ ECMS" />

                <Region HBox.hgrow="ALWAYS" />

                <!-- Username -->
                <Label fx:id="usernameLabel" style="-fx-text-fill: #c8e6c9; -fx-font-size: 13px; -fx-padding: 0 16 0 0;" />

                <!-- Logout -->
                <Button fx:id="logoutButton" onAction="#handleLogout" style="-fx-background-color: #f5f0e8; -fx-text-fill: #2e7d32;                                -fx-font-size: 12px; -fx-font-weight: bold;                                -fx-background-radius: 4; -fx-cursor: hand;                                -fx-padding: 6 14 6 14;" text="Logout" />
            </HBox>

            <!-- Breadcrumb -->
            <HBox style="-fx-background-color: #e8e0d0; -fx-padding: 6 24 6 24; -fx-border-color: #c8b89a; -fx-border-width: 0 0 1 0;">
                <Label fx:id="breadcrumbLabel" style="-fx-text-fill: #5a4a2a; -fx-font-size: 12px;" text="Dashboard" />
            </HBox>
        </VBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════
         SIDE PANEL + MAIN CONTENT
    ═══════════════════════════════════════════════════════ -->
    <center>
        <HBox spacing="0">

            <!-- Side Panel -->
            <VBox spacing="2" style="-fx-background-color: #3a5a3c; -fx-padding: 20 0 20 0; -fx-min-width: 200; -fx-max-width: 200;">

                <Label style="-fx-text-fill: #a5d6a7; -fx-font-size: 10px; -fx-font-weight: bold;                               -fx-padding: 0 0 8 18; -fx-letter-spacing: 1.5;" text="MENU" />

                <Button fx:id="navDashboard" maxWidth="Infinity" onAction="#handleNavDashboard" style="-fx-background-color: #4caf50; -fx-text-fill: #f5f0e8;                                -fx-alignment: CENTER_LEFT; -fx-padding: 12 18 12 18;                                -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 0;                                -fx-border-color: transparent;" text="🏠  Dashboard" />

                <Button fx:id="navMyComplaints" maxWidth="Infinity" onAction="#handleNavMyComplaints" style="-fx-background-color: transparent; -fx-text-fill: #c8e6c9;                                -fx-alignment: CENTER_LEFT; -fx-padding: 12 18 12 18;                                -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 0;" text="📋  My Complaints" />

                <Button fx:id="navSubmitComplaint" maxWidth="Infinity" onAction="#handleNavSubmitComplaint" style="-fx-background-color: transparent; -fx-text-fill: #c8e6c9;                                -fx-alignment: CENTER_LEFT; -fx-padding: 12 18 12 18;                                -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 0;" text="➕  Submit Complaint" />

                <Button fx:id="navFeedback" maxWidth="Infinity" onAction="#handleNavFeedback" style="-fx-background-color: transparent; -fx-text-fill: #c8e6c9;                                -fx-alignment: CENTER_LEFT; -fx-padding: 12 18 12 18;                                -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 0;" text="  Feedback" />
            </VBox>

            <!-- Main Content -->
            <ScrollPane fitToWidth="true" style="-fx-background: #f5f0e8; -fx-background-color: #f5f0e8; -fx-border-color: transparent;" HBox.hgrow="ALWAYS">
                <VBox spacing="24" style="-fx-padding: 32 32 32 32;">

                    <!-- Welcome Banner -->
                    <VBox prefHeight="44.0" prefWidth="817.0" style="-fx-background-color: #2e7d32; -fx-background-radius: 8;                                  -fx-padding: 24 28 24 28;">
                        <Label fx:id="welcomeLabel" style="-fx-text-fill: #f5f0e8; -fx-font-size: 22px; -fx-font-weight: bold; -fx-font-family: 'Georgia';" text="Welcome back!" />
                        <Label style="-fx-text-fill: #c8e6c9; -fx-font-size: 13px; -fx-wrap-text: true;" text="Track and manage your electricity complaints from your dashboard." />
                    </VBox>

                    <!-- Stats Row -->
                    <HBox spacing="16">
                        <VBox maxWidth="Infinity" style="-fx-background-color: white; -fx-background-radius: 8;                                      -fx-padding: 20 24 20 24; -fx-border-color: #ddd4c0; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #7a6a4a; -fx-font-size: 12px;" text="Total Complaints" />
                            <Label fx:id="totalComplaintsLabel" style="-fx-text-fill: #2e7d32; -fx-font-size: 28px; -fx-font-weight: bold;" text="0" />
                        </VBox>
                        <VBox maxWidth="Infinity" style="-fx-background-color: white; -fx-background-radius: 8;                                      -fx-padding: 20 24 20 24; -fx-border-color: #ddd4c0; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #7a6a4a; -fx-font-size: 12px;" text="Pending" />
                            <Label fx:id="pendingLabel" style="-fx-text-fill: #f57c00; -fx-font-size: 28px; -fx-font-weight: bold;" text="0" />
                        </VBox>
                        <VBox maxWidth="Infinity" style="-fx-background-color: white; -fx-background-radius: 8;                                      -fx-padding: 20 24 20 24; -fx-border-color: #ddd4c0; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #7a6a4a; -fx-font-size: 12px;" text="Resolved" />
                            <Label fx:id="resolvedLabel" style="-fx-text-fill: #2e7d32; -fx-font-size: 28px; -fx-font-weight: bold;" text="0" />
                        </VBox>
                        <VBox maxWidth="Infinity" style="-fx-background-color: white; -fx-background-radius: 8;                                      -fx-padding: 20 24 20 24; -fx-border-color: #ddd4c0; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #7a6a4a; -fx-font-size: 12px;" text="In Progress" />
                            <Label fx:id="inProgressLabel" style="-fx-text-fill: #1565c0; -fx-font-size: 28px; -fx-font-weight: bold;" text="0" />
                        </VBox>
                    </HBox>

                    <!-- Recent Complaints -->
                    <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 8;                                  -fx-padding: 20 24 20 24; -fx-border-color: #ddd4c0; -fx-border-radius: 8;">
                        <HBox alignment="CENTER_LEFT">
                            <Label style="-fx-text-fill: #2e3a1e; -fx-font-size: 16px; -fx-font-weight: bold;" text="Recent Complaints" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleNavMyComplaints" style="-fx-background-color: #e8f5e9; -fx-text-fill: #2e7d32;                                            -fx-font-size: 12px; -fx-font-weight: bold;                                            -fx-background-radius: 4; -fx-cursor: hand; -fx-padding: 5 12 5 12;" text="View All" />
                        </HBox>

                        <TableView fx:id="recentComplaintsTable" prefHeight="221.0" prefWidth="769.0" style="-fx-background-color: transparent; -fx-border-color: #e0d8c8; -fx-border-radius: 4;">
                            <columns>
                                <TableColumn fx:id="colComplaintId" prefWidth="220" text="Complaint ID" />
                                <TableColumn fx:id="colSubject" prefWidth="200" text="Subject" />
                                <TableColumn fx:id="colStatus" prefWidth="110" text="Status" />
                                <TableColumn fx:id="colDate" prefWidth="160" text="Date Submitted" />
                            </columns>
                            <placeholder>
                                <Label style="-fx-text-fill: #9e9e9e;" text="No complaints found." />
                            </placeholder>
                        </TableView>
                    </VBox>

                    <!-- Quick Actions -->
                    <HBox spacing="16" />

                </VBox>
            </ScrollPane>
        </HBox>
    </center>

</BorderPane>
