<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.electricity.cms.controller.SubmitComplaintController" style="-fx-background-color: #faf8f2; -fx-padding: 16;">
    <Label text="Submit Complaint" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #244631;" />

    <Label text="Category" />
    <ComboBox fx:id="categoryCombo" promptText="Select category" />

    <Label text="Description (placeholder for complaint thread)" />
    <TextArea fx:id="descriptionPlaceholder" promptText="This placeholder is reserved for future thread integration." prefRowCount="5" />

    <Button text="Submit Complaint" onAction="#submitComplaint" style="-fx-background-color: #2d7f4d; -fx-text-fill: white;" />
    <Label fx:id="statusLabel" managed="false" visible="false" />
</VBox>
