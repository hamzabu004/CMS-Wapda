<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import java.lang.String?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.electricity.cms.controller.SubmitComplaintController" style="-fx-background-color: transparent;">
    <stylesheets>
        <String fx:value="@../styles/styles.css" />
    </stylesheets>
    <content>
        <VBox spacing="14" style="-fx-padding: 16; -fx-background-color: #faf8f2;">
            <Label text="Submit Complaint" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #244631;" />

            <VBox fx:id="consumerSelectionBox" spacing="8" style="-fx-border-color: #d6cfbf; -fx-border-width: 1; -fx-padding: 10; -fx-background-color: white;" />

            <Label text="Category" />
            <ComboBox fx:id="categoryCombo" promptText="Select category" />

            <Label text="Description (placeholder for complaint thread)" />
            <TextArea fx:id="descriptionPlaceholder" promptText="This placeholder is reserved for future thread integration." prefRowCount="5" />

            <Button text="Submit Complaint" onAction="#submitComplaint" styleClass="primary-button" />
            <Label fx:id="statusLabel" managed="false" visible="false" />
        </VBox>
    </content>
</ScrollPane>
