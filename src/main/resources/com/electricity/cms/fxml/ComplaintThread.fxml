<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<VBox spacing="10"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.electricity.cms.controller.ComplaintThreadController"
      style="-fx-background-color: white; -fx-padding: 12;"
      stylesheets="@../styles/styles.css">

    <!-- Title -->
    <Label text="Complaint Thread"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2e3a1e;" />

    <!-- Messages Area -->
    <ScrollPane fx:id="scrollPane"
                fitToWidth="true"
                VBox.vgrow="ALWAYS"
                style="-fx-background: white; -fx-border-color: transparent;">

        <VBox fx:id="messagesContainer"
              spacing="10"
              style="-fx-padding: 10;" />
    </ScrollPane>

    <!-- Message Input -->
    <HBox spacing="8">

        <TextField fx:id="messageField"
                   promptText="Type your message..."
                   HBox.hgrow="ALWAYS" />

        <Button text="Send"
                fx:id="sendButton"
                onAction="#handleSend"
                style="-fx-background-color: #3a5a3c; -fx-text-fill: white;" />
    </HBox>

    <!-- Action Buttons -->
    <HBox spacing="8">
        <Button text="Mark as Resolved"
                fx:id="resolveButton"
                onAction="#handleResolve"
                style="-fx-background-color: #28a745; -fx-text-fill: white;" />
    </HBox>

</VBox>
